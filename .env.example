# Database Configuration
CPANEL_DB_HOST=localhost
CPANEL_DB_USER=varta_user
CPANEL_DB_PASS=your_secure_password
CPANEL_DB_NAME=varta_db

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# TOTP Encryption Key (32 characters for AES-256)
TOTP_ENC_KEY=default256bitkey1234567890123456

# Application Environment
APP_ENV=development
APP_DEBUG=true

# Email Configuration (Optional)
MAIL_FROM=noreply@varta.local
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
